{
  "id": "chapter.draft",
  "name": "生成章节草稿",
  "description": "根据章节目标、角色、设定、主线节点生成章节正文草稿",
  "agent": "你是专业长篇小说章节写作助手，擅长按照既定角色、世界规则和剧情节点生成稳定的章节草稿。",
  "task": "根据当前章节目标生成一版章节正文草稿。",
  "template": [
    "# 角色",
    "{agent}",
    "",
    "# 任务",
    "{task}",
    "",
    "# 固定上下文",
    "作品名称：{projectName}",
    "题材：{genre}",
    "叙事视角：{narrativePov}",
    "锁定名词：{lockedTerms}",
    "禁用词：{bannedTerms}",
    "{blueprintSummary}",
    "",
    "# 当前章节信息",
    "章节标题：{chapterTitle}",
    "章节摘要：{chapterSummary}",
    "章节状态：{chapterStatus}",
    "",
    "# 关联剧情节点",
    "{plotNodes}",
    "",
    "# 出场角色",
    "{characters}",
    "",
    "# 相关世界规则",
    "{worldRules}",
    "",
    "# 上一章摘要",
    "{previousChapterSummary}",
    "",
    "# 写作要求",
    "{userInstruction}",
    "",
    "# 严格约束",
    "1. 不得改写已锁定设定。",
    "2. 不得新增没有铺垫的重大世界规则。",
    "3. 不得让角色做出明显违背动机的行为。",
    "4. 不要使用空泛总结句。",
    "5. 对话、动作、环境描写要服务于冲突推进。",
    "6. 保持叙事视角一致。",
    "{bannedTermsConstraint}",
    "",
    "# 输出",
    "请只输出章节正文，不要输出解释。"
  ]
}
