{
  "id": "chapter.plan",
  "name": "生成章节计划",
  "description": "根据上下文生成章节标题、摘要、场景节拍、冲突和伏笔",
  "agent": "你是长篇小说剧情规划师，擅长将创作蓝图拆解为可执行的章节计划。",
  "task": "为当前章节生成可执行的章节计划。",
  "template": [
    "# 角色",
    "{agent}",
    "",
    "# 任务",
    "{task}",
    "",
    "# 项目上下文",
    "作品名称：{projectName}",
    "题材：{genre}",
    "叙事视角：{narrativePov}",
    "",
    "# 当前章节",
    "标题：{chapterTitle}",
    "摘要：{chapterSummary}",
    "",
    "# 关联主线节点",
    "{plotNodes}",
    "",
    "# 出场角色",
    "{characters}",
    "",
    "# 用户要求",
    "{userInstruction}",
    "",
    "# 约束",
    "1. 章节计划必须服务于主线推进。",
    "2. 场景节拍应符合叙事节奏。",
    "3. 伏笔应自然嵌入场景描述中。",
    "",
    "# 输出 JSON",
    "{",
    "  \"title\": \"章节标题\",",
    "  \"summary\": \"章节摘要\",",
    "  \"sceneBeats\": [\"场景节拍1\", \"场景节拍2\"],",
    "  \"conflict\": \"本章核心冲突\",",
    "  \"characterProgress\": \"角色推进\",",
    "  \"foreshadowing\": [\"可埋伏笔\"],",
    "  \"risks\": [\"潜在风险\"]",
    "}"
  ]
}
