{
  "id": "plot.create_node",
  "name": "生成剧情节点",
  "description": "根据故事主线生成剧情节点，包括冲突、转折和高潮设计",
  "agent": "你是剧情策划师，擅长设计有张力的故事节点和冲突。",
  "task": "生成一个剧情节点。",
  "template": [
    "# 角色",
    "{agent}",
    "",
    "# 任务",
    "{task}",
    "",
    "# 项目上下文",
    "作品名称：{projectName}",
    "题材：{genre}",
    "",
    "# 现有主线节点",
    "{existingPlotNodes}",
    "",
    "# 用户需求",
    "{userInstruction}",
    "",
    "# 约束",
    "1. 新节点必须符合整体主线走向。",
    "2. 节点应有明确的冲突和目标。",
    "3. 节点顺序应符合叙事节奏。",
    "",
    "# 输出 JSON",
    "{",
    "  \"title\": \"节点标题\",",
    "  \"nodeType\": \"开端|转折|冲突|失败|胜利|高潮|结局|支线\",",
    "  \"goal\": \"剧情目标\",",
    "  \"conflict\": \"核心冲突\",",
    "  \"emotionalCurve\": \"情绪曲线\",",
    "  \"order\": 1",
    "}"
  ]
}
